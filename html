// FUNÇÃO PARA PREENCHER ANOS NOS FILTROS DE DATA
function preencherAnosParaTodosFiltros() {
  console.log("📅 Preenchendo anos para filtros de data...");
  
  const selectsAno = [
    'filtroAnoCriacao', 
    'filtroAnoAtivacao', 
    'filtroAnoUltimaEtapa',
    'filtroAnoPgtoAdesao'
  ];
  
  const anoAtual = new Date().getFullYear();
  
  selectsAno.forEach(selectId => {
    const select = document.getElementById(selectId);
    if (!select) {
      console.error(`❌ Select ${selectId} não encontrado`);
      return;
    }
    
    // Se já tem opções além da primeira, não preencher novamente
    if (select.options.length > 1) {
      console.log(`✅ Select ${selectId} já preenchido`);
      return;
    }
    
    // Limpar opções exceto a primeira
    while (select.options.length > 1) {
      select.remove(1);
    }
    
    // Adicionar anos (dos últimos 5 anos até próximo ano)
    for (let ano = anoAtual - 5; ano <= anoAtual + 1; ano++) {
      const option = document.createElement('option');
      option.value = ano;
      option.textContent = ano;
      select.appendChild(option);
    }
    
    console.log(`✅ Select ${selectId} preenchido com anos`);
  });
}



