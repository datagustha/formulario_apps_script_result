function agruparCadastrosPorCNPJ(cadastros) {
  const grupos = {};
  
  cadastros.forEach(cadastro => {
    const cnpj = cadastro.cnpj;
    
    if (!grupos[cnpj]) {
      grupos[cnpj] = {
        cnpj: cnpj,
        razao_social: cadastro.razao_social,
        nome_fantasia: cadastro.nome_fantasia,
        data_criacao: cadastro.data_criacao || cadastro.criado_em || 'N/A',
        lojas: []
      };
    }
    
    grupos[cnpj].lojas.push(cadastro);
  });
  
  return Object.values(grupos);
}

function coletarDadosFormulario() {
    try {
        console.log("📋 Coletando dados do formulário...");
        
        // 🔥 1. DADOS BÁSICOS
        const razao_social = document.getElementById('razao_social')?.value?.trim() || '';
        const nome_fantasia = document.getElementById('nome_fantasia')?.value?.trim() || '';
        
        const cnpjInput = document.getElementById('cnpj_cadastro');
        let cnpj = '';
        if (cnpjInput && cnpjInput.value) {
            cnpj = cnpjInput.value.replace(/\D/g, '');
            console.log("🔢 CNPJ coletado (limpo):", cnpj);
        }
        
        const contrato_enviado = document.getElementById('contrato_enviado')?.value || '';
        const contrato_assinado = document.getElementById('contrato_assinado')?.value || '';
        
        // 🔥 CORREÇÃO: Data de ativação
        const ativacaoInput = document.getElementById('ativacao');
        let ativacao = '';
        if (ativacaoInput && ativacaoInput.value) {
            ativacao = ativacaoInput.value;
            console.log("📅 Data ativação coletada:", ativacao);
        }
        
        const link = document.getElementById('link')?.value?.trim() || '';
        
        // 🔥 CORREÇÃO: Valores monetários
        const mensalidadeInput = document.getElementById('mensalidade');
        let mensalidade = 'R$ 0,00';
        if (mensalidadeInput && mensalidadeInput.value) {
            mensalidade = mensalidadeInput.value;
            console.log("💰 Mensalidade coletada:", mensalidade);
        }
        
        const situacao = document.getElementById('situacao')?.value || '';
        
        // 🔥 CORREÇÃO: Etapa
        const etapaInput = document.getElementById('inputEtapaSearch');
        const etapa = etapaInput?.value?.trim() || '';
        console.log("📝 Etapa coletada:", etapa);
        
        const observacoes = document.getElementById('observacoes')?.value?.trim() || '';
        
        // 🔥 2. COLETAR FORNECEDORES DE FORMA ROBUSTA
        const fornecedorCheckboxes = document.querySelectorAll('input[name="fornecedor"]');
        console.log("🔍 Total de checkboxes de fornecedor:", fornecedorCheckboxes.length);
        
        const fornecedores = [];
        const fornecedoresDetalhes = [];
        
        fornecedorCheckboxes.forEach(checkbox => {
            if (checkbox.checked) {
                const fornecedorNome = checkbox.value;
                fornecedores.push(fornecedorNome);
                
                console.log(`✅ Fornecedor selecionado: ${fornecedorNome}`);
                
                // 🔥 VERIFICAR SE AS CONFIGURAÇÕES ESTÃO VISÍVEIS
                const fornecedorId = fornecedorNome.toLowerCase();
                const configDiv = document.getElementById(`config-${fornecedorId}`);
                if (configDiv && configDiv.style.display !== 'grid') {
                    console.warn(`⚠️ Configurações do fornecedor ${fornecedorId} não estão visíveis!`);
                    // Forçar a mostrar
                    configDiv.style.display = 'grid';
                }
                
                // Coletar detalhes deste fornecedor
                fornecedoresDetalhes.push({
                    nome: fornecedorNome,
                    id: fornecedorId
                });
            }
        });
        
        console.log("📋 Fornecedores selecionados:", fornecedores);
        
        if (fornecedores.length === 0) {
            console.error("❌ NENHUM FORNECEDOR SELECIONADO!");
            showMessage('error', '❌ Selecione pelo menos um fornecedor!');
            
            // Destacar visualmente
            const containerFornecedor = document.querySelector('.form-group:has(input[name="fornecedor"])');
            if (containerFornecedor) {
                containerFornecedor.style.border = '2px solid var(--danger)';
                containerFornecedor.style.animation = 'shake 0.5s ease-in-out';
                setTimeout(() => {
                    containerFornecedor.style.border = '';
                    containerFornecedor.style.animation = '';
                }, 3000);
            }
            
            return null;
        }
        
        // 🔥 3. FUNÇÃO PARA FORMATAR PERCENTUAL PARA ENVIO
        const formatarPercentualParaEnvio = (valor) => {
            if (!valor && valor !== 0) return '';
            
            console.log("📤 formatarPercentualParaEnvio recebeu:", valor, "tipo:", typeof valor);
            
            try {
                if (typeof valor === 'string') {
                    const valorLimpo = valor.replace('%', '').replace(',', '.').trim();
                    const numero = parseFloat(valorLimpo);
                    
                    if (isNaN(numero)) {
                        return '';
                    }
                    
                    // Se o número for > 1 e <= 100, dividir por 100
                    let valorFinal = numero;
                    if (numero > 1 && numero <= 100) {
                        valorFinal = numero / 100;
                        console.log(`📊 Percentual ${numero}% convertido para ${valorFinal}`);
                    } else if (numero > 100) {
                        valorFinal = numero / 100;
                        console.log(`📊 Número grande ${numero} convertido para ${valorFinal}`);
                    }
                    
                    return valorFinal.toString();
                }
                
                if (typeof valor === 'number') {
                    return valor.toString();
                }
                
                return String(valor || '');
                
            } catch (error) {
                console.error("❌ Erro em formatarPercentualParaEnvio:", error);
                return '';
            }
        };
        
        // 🔥 4. Coletar dados de cada fornecedor selecionado
        const dadosFornecedores = {};
        
        fornecedoresDetalhes.forEach(fornecedorInfo => {
            const fornecedorLower = fornecedorInfo.id;
            console.log(`📊 Coletando dados do fornecedor: ${fornecedorLower}`);
            
            // Buscar inputs de percentuais
            const mdrInput = document.querySelector(`input[name="mdr_${fornecedorLower}"]`);
            const tisInput = document.querySelector(`input[name="tis_${fornecedorLower}"]`);
            const rebateInput = document.querySelector(`input[name="rebate_${fornecedorLower}"]`);
            
            // Buscar select de treinamento
            const treinadoSelect = document.querySelector(`select[name="treinado_${fornecedorLower}"]`);
            let treinadoVal = treinadoSelect ? treinadoSelect.value : '';
            
            // 🔥 CORREÇÃO MELHORADA: Garantir que o treinamento seja salvo SEM ACENTOS
            if (treinadoVal) {
                // Converter para string e remover acentos
                treinadoVal = String(treinadoVal)
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')  // Remove acentos
                    .replace(/ç/gi, 'c')  // Remove cedilha
                    .toUpperCase()
                    .trim();
                
                console.log(`🎓 Treinamento coletado (sem acentos): "${treinadoVal}"`);
            } else {
                // Se estiver vazio, salvar como string vazia
                treinadoVal = '';
            }
            
            // Formatar e coletar percentuais
            const mdrVal = mdrInput ? formatarPercentualParaEnvio(mdrInput.value) : '';
            const tisVal = tisInput ? formatarPercentualParaEnvio(tisInput.value) : '';
            const rebateVal = rebateInput ? formatarPercentualParaEnvio(rebateInput.value) : '';

            console.log(`  ${fornecedorInfo.nome}: MDR=${mdrVal || 'não preenchido'}, TIS=${tisVal || 'não preenchido'}, Rebate=${rebateVal || 'não preenchido'}, Treinado="${treinadoVal}"`);
            
            // Adicionar ao objeto de dados
            dadosFornecedores[`mdr_${fornecedorLower}`] = mdrVal;
            dadosFornecedores[`tis_${fornecedorLower}`] = tisVal;
            dadosFornecedores[`rebate_${fornecedorLower}`] = rebateVal;
            dadosFornecedores[`treinado_${fornecedorLower}`] = treinadoVal;
        });
        
        // 🔥 5. Dados base para todos os waitlabels
        const dadosBase = {
            razao_social,
            nome_fantasia,
            cnpj,
            fornecedor: fornecedores.join(', '),
            contrato_enviado,
            contrato_assinado,
            ativacao,
            link,
            mensalidade,
            situacao,
            etapa,
            observacoes,
            ...dadosFornecedores
        };
        
        // 🔥 6. CAMPOS ESPECÍFICOS PARA CADA WAITLABEL
        if (waitlabelAtual === 'Sim_Facilita') {
            // SIM FACILITA
            const plano = document.getElementById('plano')?.value || '';
            const vencimento = document.getElementById('vencimento')?.value || '';
            const metodo_pgto = document.getElementById('metodo_pgto')?.value || '';
            const adesaoInput = document.getElementById('adesao');
            const adesao = adesaoInput ? adesaoInput.value : 'R$ 0,00';
            const pgto_adesaoInput = document.getElementById('pgto_adesao');
            const pgto_adesao = pgto_adesaoInput ? pgto_adesaoInput.value : '';
            
            dadosBase.plano = plano;
            dadosBase.vencimento = vencimento;
            dadosBase.metodo_pgto = metodo_pgto;
            dadosBase.adesao = adesao;
            dadosBase.pgto_adesao = pgto_adesao;
            dadosBase.mensalidade_sim = '0'; // Para SIM, sempre 0
            
            console.log("🎯 Campos SIM coletados:", { 
                plano, vencimento, metodo_pgto, adesao, pgto_adesao 
            });
        } else {
            // OUTROS WAITLABELS
            const mensalidade_simInput = document.getElementById('mensalidade_sim');
            const mensalidade_sim = mensalidade_simInput ? mensalidade_simInput.value : 'R$ 0,00';
            const adesaoInput = document.getElementById('adesao');
            const adesao = adesaoInput ? adesaoInput.value : 'R$ 0,00';
            
            dadosBase.mensalidade_sim = mensalidade_sim;
            dadosBase.adesao = adesao;
            
            console.log("🎯 Campos outros waitlabels coletados:", { 
                mensalidade_sim, adesao 
            });
        }
        
        // 🔥 7. DEBUG: MOSTRAR TODOS OS DADOS COLETADOS
        console.log("✅ DADOS FINAIS COLETADOS COM SUCESSO:");
        console.log("📋 Dados básicos:", {
            razao_social: dadosBase.razao_social,
            cnpj: dadosBase.cnpj,
            fornecedor: dadosBase.fornecedor,
            situacao: dadosBase.situacao,
            etapa: dadosBase.etapa
        });
        
        console.log("🎓 Campos de treinamento coletados:");
        for (const key in dadosBase) {
            if (key.includes('treinado')) {
                console.log(`  ${key}: "${dadosBase[key]}"`);
            }
        }
        
        console.log("📊 Campos de percentuais coletados:");
