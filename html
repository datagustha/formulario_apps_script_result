            if (key.includes('mdr_') || key.includes('tis_') || key.includes('rebate_')) {
                console.log(`  ${key}: "${dadosBase[key]}"`);
            }
        }
        
        return dadosBase;
        
    } catch (error) {
        console.error('❌ ERRO CRÍTICO ao coletar dados do formulário:', error);
        showMessage('error', 'Erro ao coletar dados: ' + error.message);
