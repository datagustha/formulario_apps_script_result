function filtrarPorData(dataString, mesFiltro, anoFiltro) {
  if (!dataString || dataString === 'N/A') return false;
  
  try {
    let data;
    
    if (dataString.includes('/')) {
      const partes = dataString.split(' ')[0].split('/');
      if (partes.length === 3) {
        data = new Date(partes[2], partes[1] - 1, partes[0]);
      }
    } else if (dataString.includes('-')) {
      data = new Date(dataString.split('T')[0]);
    } else {
      data = new Date(dataString);
    }
    
    if (!data || isNaN(data.getTime())) return false;
    
    const mesData = String(data.getMonth() + 1).padStart(2, '0');
    const anoData = String(data.getFullYear());
    
    if (mesFiltro && mesData !== mesFiltro) return false;
    if (anoFiltro && anoData !== anoFiltro) return false;
    
    return true;
  } catch (e) {
    return false;
  }
}

// Função para obter a data mais recente de um grupo de lojas
function obterDataMaisRecenteDoGrupo(lojas) {
  let dataMaisRecente = null;
  
  lojas.forEach(loja => {
    if (loja.ultima_etapa && loja.ultima_etapa !== 'N/A') {
      try {
        const data = converterParaData(loja.ultima_etapa);
        if (data && (!dataMaisRecente || data > dataMaisRecente)) {
          dataMaisRecente = data;
        }
      } catch (e) {
        console.log('Erro ao converter data:', e);
      }
    }
  });
  
  return dataMaisRecente || new Date(0); // Retorna data mínima se não tiver
}
// Procure pela função converterParaData (por volta da linha 1000) e atualize:
function converterParaData(dataString) {
    if (!dataString || dataString === 'N/A' || dataString === '' || dataString === 'undefined') {
        console.log("📭 Data vazia ou inválida:", dataString);
        return null;
    }
    
    console.log("📅 Tentando converter data:", dataString);
    
    try {
        // Se já for um objeto Date
        if (dataString instanceof Date) {
            return dataString;
        }
        
        // 🔥 CORREÇÃO: Formato DD/MM/AAAA HH:mm:ss (como 23/01/2026 16:32:35)
        if (dataString.includes('/') && dataString.includes(':')) {
            const partes = dataString.split(' ');
            if (partes.length >= 1) {
                const dataParte = partes[0];
                const dataPartes = dataParte.split('/');
                if (dataPartes.length === 3) {
                    const [dia, mes, ano] = dataPartes;
                    console.log(`  → Formato DD/MM/AAAA HH:mm:ss detectado: ${dia}/${mes}/${ano}`);
                    
                    // Se tiver hora, incluir na criação do Date
                    if (partes.length >= 2 && partes[1].includes(':')) {
                        const horaPartes = partes[1].split(':');
                        const [hora, minuto, segundo] = horaPartes;
                        return new Date(
                            parseInt(ano), 
                            parseInt(mes) - 1, 
                            parseInt(dia),
                            parseInt(hora || 0), 
                            parseInt(minuto || 0), 
                            parseInt(segundo || 0)
                        );
                    } else {
                        return new Date(parseInt(ano), parseInt(mes) - 1, parseInt(dia));
                    }
                }
            }
        }
        
        // Formato DD/MM/AAAA (sem hora)
        if (dataString.includes('/')) {
            const partes = dataString.split(' ')[0].split('/');
            if (partes.length === 3) {
                const [dia, mes, ano] = partes;
                console.log(`  → Formato DD/MM/AAAA detectado: ${dia}/${mes}/${ano}`);
                return new Date(parseInt(ano), parseInt(mes) - 1, parseInt(dia));
            }
        }
        
        // Formato AAAA-MM-DD (ISO)
        if (dataString.includes('-')) {
            console.log(`  → Formato ISO detectado: ${dataString}`);
            return new Date(dataString.split('T')[0]);
        }
        
        // Tentar parse direto
        const date = new Date(dataString);
        if (!isNaN(date.getTime())) {
            console.log(`  → Parse direto bem-sucedido: ${date}`);
            return date;
        }
        
        console.log("❌ Não foi possível converter a data:", dataString);
        return null;
    } catch (e) {
        console.log('❌ Erro ao converter data:', dataString, e);
        return null;
    }
}

function formatarPercentualCorrigido(percentual) {
    if (!percentual && percentual !== 0) {
        console.log("📭 Percentual vazio:", percentual);
        return 'N/A';
    }
    
    console.log("📊 formatarPercentualCorrigido recebeu:", percentual, "tipo:", typeof percentual);
    
    try {
        // Se já for string formatada com %, retornar como está
        if (typeof percentual === 'string' && percentual.includes('%')) {
            console.log("✅ Já formatado com %:", percentual);
            return percentual;
        }
        
        // Converter para número
        let numero;
        if (typeof percentual === 'string') {
            // Remove % e converte vírgula para ponto
            const strLimpa = percentual.replace('%', '').replace(',', '.').trim();
            numero = parseFloat(strLimpa);
        } else {
            numero = parseFloat(percentual);
        }
        
        if (isNaN(numero)) {
            console.log("⚠️ Não é número válido:", percentual);
            return String(percentual);
        }
        
        console.log("🔢 Número convertido:", numero);
        
        // ⚠️ AQUI ESTÁ A CORREÇÃO: MULTIPLICAR POR 100!
        // 0.08 → "8,00%" ✓
        // 0.0553 → "5,53%" ✓
        // 0.688 → "68,80%" ✓
        // 4.20 → "420,00%" (se vier como 4.20, significa 420%)
        
        const valorMultiplicado = numero * 100;
        const resultado = valorMultiplicado.toFixed(2).replace('.', ',') + '%';
        
        console.log("✅ Resultado final:", percentual, "→", numero, "→", resultado);
        return resultado;
        
    } catch (error) {
        console.error("❌ Erro em formatarPercentualCorrigido:", error);
        return String(percentual);
    }
}

