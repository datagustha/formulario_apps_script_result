  let pgtoAdesaoCNPJ = 'N/A';
  
  for (const loja of grupoCNPJ.lojas) {
    if (mensalidadeCNPJ === 'R$ 0,00' && loja.mensalidade && loja.mensalidade !== 'R$ 0,00' && loja.mensalidade !== 0) {
      mensalidadeCNPJ = formatarMoedaParaInput(loja.mensalidade);
