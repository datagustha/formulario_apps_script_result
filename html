function removerAcentos(texto) {
    if (!texto) return '';
    
    return texto
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')  // Remove acentos
        .replace(/ç/g, 'c')              // Remove cedilha
        .replace(/Ç/g, 'C')              // Remove cedilha maiúscula
        .replace(/[^\w\s]/gi, '')        // Remove caracteres especiais
        .toUpperCase();
}

function preencherDadosFornecedor(fornecedorId, dados) {
    console.log(`📝 PREENCHENDO DADOS PARA FORNECEDOR: ${fornecedorId}`, dados);
    
    // 🔥 FUNÇÃO PARA BUSCAR VALOR EM DIFERENTES FORMATOS
    const buscarValor = (prefixo) => {
        const padroes = [
            `${prefixo}_${fornecedorId.toLowerCase()}`,
            `${prefixo}_${fornecedorId.toUpperCase()}`,
            `${prefixo}_${fornecedorId}`,
            `${prefixo}${fornecedorId.toLowerCase()}`,
            `${prefixo}${fornecedorId.toUpperCase()}`,
            `${prefixo}${fornecedorId}`,
            prefixo
        ];
        
        for (const padrao of padroes) {
            const valor = dados[padrao];
            if (valor !== undefined && valor !== null && valor !== '') {
                console.log(`✅ ${prefixo} encontrado com padrão: ${padrao} = ${valor}`);
                return valor;
            }
        }
        
        // 🔥 BUSCAR EM TODAS AS CHAVES DO OBJETO
        const todasChaves = Object.keys(dados);
        for (const chave of todasChaves) {
            if (chave.toUpperCase().includes(prefixo.toUpperCase()) && 
                chave.toUpperCase().includes(fornecedorId.toUpperCase())) {
                console.log(`✅ ${prefixo} encontrado em chave: ${chave} = ${dados[chave]}`);
                return dados[chave];
            }
        }
        
        console.log(`❌ ${prefixo} não encontrado para ${fornecedorId}`);
        return '';
    };
    
    // BUSCAR VALORES
    const mdrValor = buscarValor('mdr');
    const tisValor = buscarValor('tis');
    const rebateValor = buscarValor('rebate');
    const treinadoValor = buscarValor('treinado');
    
    // 🔥 FUNÇÃO PARA FORMATAR PERCENTUAL PARA INPUT
    const formatarPercentInput = (valor) => {
        if (!valor && valor !== 0) return '';
        
        console.log(`🔢 Formatando ${valor} (tipo: ${typeof valor})`);
        
        // Se já tem %, usar como está
        if (typeof valor === 'string' && valor.includes('%')) {
            return valor;
        }
        
        // Tentar converter para número
        let numero;
        if (typeof valor === 'string') {
            // Remover tudo que não for número, vírgula ou ponto
            const strLimpa = valor.replace(/[^\d,.-]/g, '').replace(',', '.');
            numero = parseFloat(strLimpa);
        } else {
            numero = parseFloat(valor);
        }
        
        if (isNaN(numero)) {
            console.log(`⚠️ Não é número: ${valor}`);
            return '';
        }
        
        // Se número for decimal pequeno (0.03), multiplicar por 100
        if (numero < 1 && numero > 0) {
            console.log(`📊 Decimal detectado (${numero}): multiplicando por 100`);
            numero = numero * 100;
        }
        
        // Se número for muito grande (ex: 300), dividir por 100
        if (numero > 100) {
            console.log(`📊 Número grande detectado (${numero}): dividindo por 100`);
            numero = numero / 100;
        }
        
        // Formatar com 2 casas decimais
        const resultado = numero.toFixed(2).replace('.', ',') + '%';
        console.log(`✅ Formatado: ${valor} → ${resultado}`);
        return resultado;
    };
    
    // PREENCHER MDR
    const mdrInput = document.querySelector(`input[name="mdr_${fornecedorId}"]`);
    if (mdrInput) {
        const mdrFormatado = formatarPercentInput(mdrValor);
        mdrInput.value = mdrFormatado;
        
        // Atualizar display
        const mdrDisplay = document.getElementById(`mdr_${fornecedorId}_display`);
        if (mdrDisplay) {
            mdrDisplay.textContent = mdrFormatado;
        }
        console.log(`✅ MDR preenchido: ${mdrFormatado}`);
    } else {
        console.error(`❌ Input MDR não encontrado para: ${fornecedorId}`);
    }
    
    // PREENCHER TIS
    const tisInput = document.querySelector(`input[name="tis_${fornecedorId}"]`);
    if (tisInput) {
        const tisFormatado = formatarPercentInput(tisValor);
        tisInput.value = tisFormatado;
        
        // Atualizar display
        const tisDisplay = document.getElementById(`tis_${fornecedorId}_display`);
        if (tisDisplay) {
            tisDisplay.textContent = tisFormatado;
        }
        console.log(`✅ TIS preenchido: ${tisFormatado}`);
    } else {
        console.error(`❌ Input TIS não encontrado para: ${fornecedorId}`);
    }
    
    // PREENCHER REBATE
    const rebateInput = document.querySelector(`input[name="rebate_${fornecedorId}"]`);
    if (rebateInput) {
