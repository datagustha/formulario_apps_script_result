// 🔥 NOVA FUNÇÃO CORRIGIDA PARA FILTRAGEM DE DATA
function filtrarPorDataCorrigida(dataString, mesFiltro, anoFiltro) {
  // 🔥 SE A DATA FOR NULA/VAZIA, JÁ FOI TRATADO - AQUI NÃO ENTRA
  
  try {
    let dataObj = null;
    
    // Formato DD/MM/AAAA
    if (dataString.includes('/')) {
      const partes = dataString.split(' ')[0].split('/');
      if (partes.length === 3) {
        const [dia, mes, ano] = partes;
        if (dia && mes && ano) {
          dataObj = new Date(parseInt(ano), parseInt(mes) - 1, parseInt(dia));
        }
      }
    }
    // Formato AAAA-MM-DD (ISO)
    else if (dataString.includes('-')) {
      dataObj = new Date(dataString.split('T')[0]);
    }
    // Tentar parse direto
    else {
      dataObj = new Date(dataString);
    }
    
    // 🔥 VERIFICAR SE A DATA É VÁLIDA
    if (!dataObj || isNaN(dataObj.getTime())) {
      console.log("❌ Data inválida para filtro:", dataString);
      return false;
    }
    
    const mesData = String(dataObj.getMonth() + 1).padStart(2, '0');
    const anoData = String(dataObj.getFullYear());
    
