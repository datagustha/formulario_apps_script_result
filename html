// FUNÇÃO PARA ATUALIZAR DISPLAY DO FILTRO
function atualizarDisplayFiltroData(containerId, mes, ano, label) {
  const container = document.getElementById(containerId);
  
  if (!container) {
    console.error(`❌ Container ${containerId} não encontrado`);
    return;
  }
  
  if (!mes && !ano) {
    container.style.display = 'none';
    container.innerHTML = '';
    return;
  }
  
  container.style.display = 'flex';
  
  let textoFiltro = '';
  if (mes && ano) {
    const nomeMes = obterNomeMes(mes);
    textoFiltro = `${label}: ${nomeMes}/${ano}`;
  } else if (mes) {
    textoFiltro = `${label}: ${obterNomeMes(mes)}`;
  } else if (ano) {
    textoFiltro = `${label}: ${ano}`;
  }
  
  container.innerHTML = `
    <div class="tag" style="background: var(--info);">
      <i class="fas fa-calendar"></i> ${textoFiltro}
      <button class="remover" onclick="removerFiltroData('${containerId}')">
        <i class="fas fa-times"></i>
      </button>
    </div>
  `;
}

// FUNÇÃO PARA OBTER NOME DO MÊS
function obterNomeMes(numeroMes) {
  const meses = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho',
                 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];
  const mesIndex = parseInt(numeroMes) - 1;
  return meses[mesIndex] || '';
