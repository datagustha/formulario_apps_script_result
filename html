// FUNÇÃO PARA ENCONTRAR PAGAMENTO ADESÃO MAIS RECENTE
function encontrarPgtoAdesaoMaisRecente(grupo) {
  if (!grupo.lojas || !Array.isArray(grupo.lojas)) return 'N/A';
  
  const lojasComPgto = grupo.lojas.filter(loja => loja.pgto_adesao && loja.pgto_adesao !== 'N/A');
  if (lojasComPgto.length === 0) return 'N/A';
  
  // Encontrar a data mais recente
  return lojasComPgto.reduce((maisRecente, atual) => {
    try {
      const dataMaisRecente = converterParaData(maisRecente.pgto_adesao);
      const dataAtual = converterParaData(atual.pgto_adesao);
      return dataAtual > dataMaisRecente ? atual : maisRecente;
    } catch (e) {
      return maisRecente;
    }
  }).pgto_adesao;
}

