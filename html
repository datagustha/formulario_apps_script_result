        dataB = obterDataMaisRecenteDoGrupo(b.lojas);
        return new Date(dataB) - new Date(dataA);
        
      case 'ultima_etapa_antigo':
        dataA = obterDataMaisRecenteDoGrupo(a.lojas);
        dataB = obterDataMaisRecenteDoGrupo(b.lojas);
        return new Date(dataA) - new Date(dataB);
        
      case 'pgto_adesao_recente':
        dataA = converterParaData(encontrarPgtoAdesaoMaisRecente(a));
        dataB = converterParaData(encontrarPgtoAdesaoMaisRecente(b));
        return new Date(dataB) - new Date(dataA);
        
