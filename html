            } else if (!etapaSelecionada) {
                dados.etapa = situacaoSelecionada;
            }
        }
    }

    dados.acao = 'atualizar';
    dados.id = cadastroAtualId;

    // 🔥 DEBUG: Verifique os dados antes de enviar
    console.log("🎯 Dados finais para envio:", dados);
    console.log("🎯 Waitlabel atual:", waitlabelAtual);
    console.log("🎯 ID do cadastro:", cadastroAtualId);

    mostrarPopupAtualizando();

    const btnAtualizar = document.getElementById('btnAtualizar');
    const btnOriginalHTML = btnAtualizar.innerHTML;
    btnAtualizar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Atualizando...';
    btnAtualizar.disabled = true;

    // 🔥🔥🔥 CORREÇÃO CRÍTICA: TROQUE A FUNÇÃO CHAMADA
    google.script.run
        .withSuccessHandler(function(res) {
            esconderPopupAtualizando();
            
            btnAtualizar.innerHTML = btnOriginalHTML;
            btnAtualizar.disabled = false;
            
            console.log("📥 Resposta do servidor:", res);
            
            if (res && res.success) {
                showMessage('success', '✅ ' + res.message);
                
                // Limpar formulário após sucesso
                limparFormulario();
                
                // Recarregar tabela se visível
                if (document.getElementById('secaoCadastros').style.display === 'block') {
                    restaurarFiltros(filtrosSalvos);
                }
                
                // 🔥 Opcional: Forçar recarregamento dos dados
                setTimeout(() => {
                    if (typeof carregarDados === 'function') {
                        carregarDados();
                    }
                }, 1000);
            } else {
                showMessage('error', '❌ ' + (res ? res.message : 'Resposta inválida do servidor'));
            }
        })
        .withFailureHandler(function(error) {
            esconderPopupAtualizando();
            
            btnAtualizar.innerHTML = btnOriginalHTML;
            btnAtualizar.disabled = false;
            
            console.error("❌ Erro detalhado na chamada:", error);
            console.error("❌ Stack trace:", error.stack);
            
            showMessage('error', '❌ Erro ao atualizar: ' + error.message);
        })
        .processarCadastroComWaitlabel(dados, waitlabelAtual); // ← AQUI ESTÁ A CORREÇÃO!
}

