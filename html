function configurarValidacaoEmTempoReal() {
  const camposObrigatorios = ['razao_social', 'cnpj_cadastro', 'contrato_enviado', 'contrato_assinado', 'mensalidade', 'situacao'];
  
  camposObrigatorios.forEach(campoId => {
    const elemento = document.getElementById(campoId);
    if (elemento) {
      elemento.addEventListener('blur', function() {
        if (!this.value || this.value.trim() === '') {
          this.classList.add('campo-obrigatorio');
        } else {
          this.classList.remove('campo-obrigatorio');
        }
      });
      
      elemento.addEventListener('input', function() {
        if (this.value && this.value.trim() !== '') {
          this.classList.remove('campo-obrigatorio');
        }
      });
    }
  });
  
  const containerFornecedor = document.querySelector('.form-group:has(input[name="fornecedor"])');
  if (containerFornecedor) {
    const checkboxes = containerFornecedor.querySelectorAll('input[name="fornecedor"]');
    checkboxes.forEach(checkbox => {
      checkbox.addEventListener('change', function() {
        const algumSelecionado = Array.from(checkboxes).some(cb => cb.checked);
        if (algumSelecionado) {
          containerFornecedor.classList.remove('fornecedores-invalido');
        }
      });
    });
  }
}

function formatarMoeda(input) {
  let value = input.value.replace(/\D/g, '');
  
  if (value.length === 0) {
    input.value = 'R$ 0,00';
    return;
  }
  
  let number = parseInt(value) / 100;
  
  input.value = number.toLocaleString('pt-BR', {
    style: 'currency',
    currency: 'BRL',
    minimumFractionDigits: 2
  });
}

function formatarMoedaParaInput(valor) {
  if (!valor && valor !== 0) return 'R$ 0,00';
  
  if (typeof valor === 'string') {
    if (valor.includes('R$')) return valor;
    
    const number = parseFloat(valor.replace(',', '.'));
    if (!isNaN(number)) {
      return number.toLocaleString('pt-BR', {
        style: 'currency',
        currency: 'BRL',
        minimumFractionDigits: 2
      });
    }
  }
  
  if (typeof valor === 'number') {
    return valor.toLocaleString('pt-BR', {
      style: 'currency',
      currency: 'BRL',
      minimumFractionDigits: 2
    });
  }
  
  return 'R$ 0,00';
}

function formatarDataParaExibicao(data) {
    if (!data || data === 'N/A' || data === 'undefined' || data === '' || data === null) {
        return 'N/A';
    }
    
    console.log("📅 formatarDataParaExibicao recebeu:", data, "tipo:", typeof data);
    
    try {
        // 🔥 NOVO: Se já estiver no formato DD/MM/AAAA HH:mm:ss (como 23/01/2026 16:32:35)
        if (typeof data === 'string' && data.includes('/') && data.includes(':')) {
            const partes = data.split(' ');
            if (partes.length >= 1) {
                // Retornar apenas a data (parte antes do espaço)
                return partes[0];
            }
        }
        
        // Se já estiver no formato DD/MM/AAAA (sem hora)
        if (typeof data === 'string' && data.includes('/') && data.length === 10) {
            const partes = data.split('/');
            if (partes.length === 3 && partes[0].length === 2 && partes[1].length === 2 && partes[2].length === 4) {
                return data;
            }
        }
        
        // Se for string com formato ISO (YYYY-MM-DD)
        if (typeof data === 'string' && data.includes('-')) {
            const partes = data.split('T')[0].split('-');
            if (partes.length === 3) {
                const [ano, mes, dia] = partes;
                return `${dia.padStart(2, '0')}/${mes.padStart(2, '0')}/${ano}`;
            }
        }
        
        // Se for uma string complexa com GMT
        if (typeof data === 'string' && (data.includes('GMT') || data.includes('('))) {
            // Extrair apenas a parte da data
            const match = data.match(/(\w{3} \w{3} \d{2} \d{4})/);
            if (match) {
                const dateObj = new Date(match[0]);
                if (!isNaN(dateObj.getTime())) {
                    const dia = String(dateObj.getDate()).padStart(2, '0');
                    const mes = String(dateObj.getMonth() + 1).padStart(2, '0');
                    const ano = dateObj.getFullYear();
                    return `${dia}/${mes}/${ano}`;
                }
            }
        }
        
        // 🔥 NOVO: Se for um objeto Date ou timestamp
        if (data instanceof Date) {
            if (!isNaN(data.getTime())) {
                const dia = String(data.getDate()).padStart(2, '0');
                const mes = String(data.getMonth() + 1).padStart(2, '0');
                const ano = data.getFullYear();
                return `${dia}/${mes}/${ano}`;
            }
        }
        
        // Tentar criar objeto Date
        const dateObj = new Date(data);
        if (!isNaN(dateObj.getTime())) {
            const dia = String(dateObj.getDate()).padStart(2, '0');
            const mes = String(dateObj.getMonth() + 1).padStart(2, '0');
            const ano = dateObj.getFullYear();
            return `${dia}/${mes}/${ano}`;
        }
        
        return 'N/A';
    } catch (error) {
        console.error('❌ Erro ao formatar data:', error, 'Data:', data);
        return 'N/A';
    }
}

function getSituacaoClass(situacao) {
  if (!situacao) return 'situacao-andamento';
  
  const situacaoLower = situacao.toLowerCase();
  
  if (situacaoLower.includes('novo registro')) return 'situacao-novo-registro';
  else if (situacaoLower.includes('cadastrado')) return 'situacao-cadastrado';
  else if (situacaoLower.includes('em andamento')) return 'situacao-andamento';
  else if (situacaoLower.includes('rejeitado')) return 'situacao-rejeitado';
  else if (situacaoLower.includes('descredenciado')) return 'situacao-descredenciado';
  else if (situacaoLower.includes('desistiu')) return 'situacao-desistiu';
  else return 'situacao-andamento';
}

