// FUNÇÕES PARA TREINAMENTO
function calcularTreinamentoGrupo(lojas) {
  if (!lojas || lojas.length === 0) return 'treinamento-indefinido';
  
  // Contar quantos estão treinados e não treinados
  let simCount = 0;
  let naoCount = 0;
  let indefinidoCount = 0;
  
  lojas.forEach(loja => {
    const fornecedor = loja.fornecedor?.toLowerCase();
    const treinado = loja[`treinado_${fornecedor}`] || loja.treinado || '';
    
    const treinadoUpper = treinado.toString().toUpperCase().trim();
    
    if (treinadoUpper === 'SIM' || treinadoUpper === 'S' || treinadoUpper === 'YES' || treinadoUpper === 'Y' || treinadoUpper === '1') {
      simCount++;
    } else if (treinadoUpper === 'NÃO' || treinadoUpper === 'NAO' || treinadoUpper === 'NO' || treinadoUpper === 'N' || treinadoUpper === '0') {
      naoCount++;
    } else {
      indefinidoCount++;
    }
  });
  
  console.log(`📊 Contagem de treinamento - SIM: ${simCount}, NÃO: ${naoCount}, Indefinido: ${indefinidoCount}`);
  
  // 🔥 REGRA CORRIGIDA:
  // 1. Se TEM PELO MENOS UM "NÃO" → "NÃO"
  // 2. Se TODOS SÃO "SIM" → "SIM"
  // 3. Se não tem "NÃO" e não tem "SIM" → "Indefinido"
  // 4. Se tem "SIM" e "Indefinido" (mas nenhum "NÃO") → "Indefinido"
  
  if (naoCount > 0) {
    console.log(`⚠️ Encontrado ${naoCount} fornecedor(es) NÃO treinado(s) → Retorna NÃO`);
    return 'treinamento-nao';
  }
  
  if (simCount > 0 && naoCount === 0 && indefinidoCount === 0) {
    console.log(`✅ Todos os ${simCount} fornecedores treinados → Retorna SIM`);
    return 'treinamento-sim';
  }
  
  console.log(`❓ Situação indefinida → Retorna Indefinido`);
  return 'treinamento-indefinido';
}

