        let treinadoFormatado = '';
        if (treinadoValor) {
            const treinadoString = String(treinadoValor);
            const treinadoNormalizado = treinadoString
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')  // Remove acentos
                .replace(/ç/gi, 'c')              // Remove cedilha
                .toUpperCase()
                .trim();
            
            console.log(`🎓 Valor normalizado: "${treinadoNormalizado}"`);
            
            // Mapear para os valores do select
            if (treinadoNormalizado === 'SIM' || 
                treinadoNormalizado === 'S' || 
                treinadoNormalizado === 'TRUE' || 
                treinadoNormalizado === '1' ||
                treinadoNormalizado === 'YES' ||
                treinadoNormalizado === 'Y') {
                treinadoFormatado = 'SIM';
            } else if (treinadoNormalizado === 'NÃO' || 
                      treinadoNormalizado === 'NAO' || 
                      treinadoNormalizado === 'N' || 
                      treinadoNormalizado === 'FALSE' || 
                      treinadoNormalizado === '0' ||
                      treinadoNormalizado === 'NO') {
                treinadoFormatado = 'NAO';
            } else {
                console.log(`⚠️ Valor não reconhecido: "${treinadoNormalizado}"`);
            }
        }
        
        // Definir valor no select
        if (treinadoFormatado) {
            treinadoSelect.value = treinadoFormatado;
            console.log(`✅ Treinamento definido: "${treinadoSelect.value}"`);
        } else {
            treinadoSelect.value = '';
