// 🔥 ADICIONE ESTAS FUNÇÕES NO INÍCIO DO SCRIPT (após as variáveis globais)
function removerAcentos(texto) {
    if (!texto) return '';
    return texto.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
}

function normalizarPlano(plano) {
    if (!plano) return '';
    
    return removerAcentos(plano)
        .toUpperCase()
        .replace(/\s+/g, '_') // Espaços por underscore
        .replace(/Ç/g, 'C'); // Ç por C se necessário
}

function isAplicarATodosMode() {
  return Object.keys(camposParaAplicarATodos).some(campo => camposParaAplicarATodos[campo]) || 
         document.getElementById('btnAplicarATodos')?.style.display === 'inline-flex' ||
         document.getElementById('cardCadastro')?.classList.contains('modo-aplicar-todos');
}

// 🔥 CORREÇÃO: Função para formatar percentual corretamente antes de enviar
function formatarPercentualParaEnvio(valor) {
  if (!valor && valor !== 0) return '';
  
  console.log("📤 formatarPercentualParaEnvio recebeu:", valor);
  
  try {
    if (typeof valor === 'string') {
      // Remover % e converter vírgula para ponto
      const valorLimpo = valor.replace('%', '').replace(',', '.').trim();
      const numero = parseFloat(valorLimpo);
      
      if (isNaN(numero)) {
        return '';
      }
      
      // Retornar o número puro (sem %) - o backend vai converter para decimal
      return numero.toString();
    }
    
    if (typeof valor === 'number') {
      return valor.toString();
    }
    
    return String(valor || '');
    
  } catch (error) {
    console.error("❌ Erro em formatarPercentualParaEnvio:", error);
    return '';
  }
}

// 🔥 CORREÇÃO: Adicionar esta função para testar conexão
function testarConexao() {
  console.log("🔧 Testando conexão com o Google Apps Script...");
  
  google.script.run
    .withSuccessHandler(function(result) {
      console.log("✅ Teste de conexão bem-sucedido:", result);
      showMessage('success', '✅ Conexão com servidor estabelecida!');
    })
    .withFailureHandler(function(error) {
      console.error("❌ Erro na conexão:", error);
      showMessage('error', '❌ Erro na conexão com o servidor: ' + error.message);
    })
    .testar();
}
