function formatarDataCriacaoCorretamente(grupoCNPJ) {
    console.log("🔍 Buscando data de criação para CNPJ:", grupoCNPJ.cnpj);
    
    if (!grupoCNPJ || !grupoCNPJ.lojas || grupoCNPJ.lojas.length === 0) {
        console.log("❌ Nenhuma loja encontrada para este CNPJ");
        return 'N/A';
    }
    
    // Tentar encontrar a data de criação mais antiga
    let dataCriacaoMaisAntiga = null;
    
    for (const loja of grupoCNPJ.lojas) {
        const dataCriacao = loja.data_criacao || loja.criado_em;
        console.log(`  📝 Loja ${loja.fornecedor} - data_criacao:`, loja.data_criacao, "criado_em:", loja.criado_em);
        
        if (dataCriacao && dataCriacao !== 'N/A' && dataCriacao !== 'undefined' && dataCriacao !== '') {
            // Tentar converter para Date para comparação
            try {
                const dataObj = converterParaData(dataCriacao);
                if (dataObj) {
                    if (!dataCriacaoMaisAntiga || dataObj < dataCriacaoMaisAntiga) {
                        dataCriacaoMaisAntiga = dataObj;
                    }
                }
            } catch (error) {
                console.log("  ⚠️ Erro ao converter data:", dataCriacao);
            }
        }
    }
    
    if (dataCriacaoMaisAntiga) {
        const resultado = formatarDataParaExibicao(dataCriacaoMaisAntiga);
        console.log(`✅ Data de criação encontrada: ${resultado}`);
        return resultado;
    }
    
    console.log(`❌ Nenhuma data de criação válida encontrada`);
    return 'N/A';
}

