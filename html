  // 🔥 ADICIONAR: Encontrar data de ativação mais antiga
  const dataAtivacaoMaisAntiga = encontrarDataAtivacaoMaisAntiga(grupoCNPJ);
  
  // Formatar mensalidade, mensalidade SIM e adesão do CNPJ
