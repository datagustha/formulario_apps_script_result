      cadastro.situacao === situacaoAtiva
    );
    console.log("✅ Após filtro situação:", resultado.length);
  }
  
  // 2. FILTRO POR ETAPAS
  if (filtrosAtivos.etapas && filtrosAtivos.etapas.length > 0) {
