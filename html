// 🔥🔥🔥 FUNÇÃO formatarPercentual FORA DO DOMContentLoaded 🔥🔥🔥
function formatarPercentual(input, displayId) {
  console.log("🔥 formatarPercentual chamado para:", input.name);
  
  let startPos = input.selectionStart;
  let endPos = input.selectionEnd;
  let valor = input.value;
  
  // Remove %
  valor = valor.replace('%', '');
  
  // Mantém apenas números, vírgula e ponto
  let numeros = valor.replace(/[^\d,\.]/g, '');
  
  if (numeros === '') {
    input.value = '';
    if (displayId) {
      document.getElementById(displayId).textContent = '';
    }
    return;
  }
  
  // Converte para número
  let numero = parseFloat(numeros.replace(',', '.'));
  
  if (isNaN(numero)) {
    input.value = '';
    if (displayId) {
      document.getElementById(displayId).textContent = '';
    }
    return;
  }
  
  // Formata com 2 casas decimais
  let valorPercentual = numero.toFixed(2);
  const valorFormatado = valorPercentual.replace('.', ',') + '%';
  
  // Atualiza input
  input.value = valorFormatado;
  
  // Restaura cursor
  setTimeout(() => {
    input.setSelectionRange(startPos, startPos);
  }, 10);
  
  // Atualiza display
  if (displayId) {
    document.getElementById(displayId).textContent = valorFormatado;
  }
}


