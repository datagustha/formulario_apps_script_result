    });
    console.log("✅ Após filtro data criação:", resultado.length);
  }
  
  // 7. 🔥 FILTRO POR DATA ATIVAÇÃO
  if (filtroMesAtivacaoAtivo || filtroAnoAtivacaoAtivo) {
    resultado = resultado.filter(cadastro => {
      const dataAtivacao = cadastro.ativacao || 'N/A';
      return filtrarPorDataMelhorada(dataAtivacao, filtroMesAtivacaoAtivo, filtroAnoAtivacaoAtivo);
    });
    console.log("✅ Após filtro data ativação:", resultado.length);
  }

  // 8. 🔥 FILTRO POR DATA ÚLTIMA ETAPA
  if (filtroMesUltimaEtapaAtivo || filtroAnoUltimaEtapaAtivo) {
